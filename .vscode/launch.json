{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Launch Gestion Stock",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "build",
            "program": "${workspaceFolder}/Gestion_Stock/bin/Debug/net10.0/Gestion_Stock.dll",
            "args": [],
            "cwd": "${workspaceFolder}/Gestion_Stock",
            "stopAtEntry": false,
            "serverReadyAction": {
                "action": "openExternally",
                "pattern": "\\bNow listening on:\\s+(https?://\\S+)"
            },
            "env": {
                "ASPNETCORE_ENVIRONMENT": "Development"
            },
            "sourceFileMap": {
                "/Views": "${workspaceFolder}/Gestion_Stock/Views"
            }
        }
    ]
}
