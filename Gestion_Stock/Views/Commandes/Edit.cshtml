@model Gestion_Stock.Models.CommandeAchat
@{
    ViewData["Title"] = "Modifier commande";
}

<div class="page-header">
    <h1><i class="bi bi-pencil-square"></i> Modifier commande <span style="color:#6366f1;">#@Model.Id</span></h1>
    <a asp-action="Index" class="btn btn-outline-secondary">
        <i class="bi bi-arrow-left me-1"></i> Retour
    </a>
</div>

<div class="row">
    <div class="col-lg-7">
        <div class="card">
            <div class="card-body">
                <form asp-action="Edit" method="post">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>
                    <input type="hidden" asp-for="Id" />
                    <input type="hidden" asp-for="SousTotal" />
                    <input type="hidden" asp-for="TotalFacture" />

                    <div class="form-section">
                        <div class="form-section-title"><i class="bi bi-calendar3"></i> Informations</div>
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label asp-for="DateCommande" class="form-label"></label>
                                <input asp-for="DateCommande" class="form-control" type="date" />
                                <span asp-validation-for="DateCommande" class="text-danger small"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="Statut" class="form-label"></label>
                                <select asp-for="Statut" class="form-select">
                                    <option value="En attente">En attente</option>
                                    <option value="Confirmée">Confirmée</option>
                                    <option value="Partielle">Partielle (livraison partielle)</option>
                                    <option value="Livrée">Livrée</option>
                                    <option value="Retour">Retour</option>
                                    <option value="Annulée">Annulée</option>
                                </select>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="EmployeId" class="form-label">Employé</label>
                                <select asp-for="EmployeId" class="form-select" asp-items="ViewBag.EmployeId">
                                    <option value="">-- Sélectionner --</option>
                                </select>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="FournisseurId" class="form-label">Fournisseur</label>
                                <select asp-for="FournisseurId" class="form-select" asp-items="ViewBag.FournisseurId">
                                    <option value="">-- Sélectionner --</option>
                                </select>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="LivraisonId" class="form-label">Livraison</label>
                                <select asp-for="LivraisonId" class="form-select" asp-items="ViewBag.LivraisonId">
                                    <option value="">-- Sélectionner --</option>
                                </select>
                            </div>
                            <div class="col-md-3">
                                <label asp-for="FraisLivraison" class="form-label"></label>
                                <div class="input-group">
                                    <input asp-for="FraisLivraison" class="form-control" type="number" step="0.01" min="0" />
                                    <span class="input-group-text">DT</span>
                                </div>
                            </div>
                            <div class="col-md-3">
                                <label asp-for="TauxTVA" class="form-label"></label>
                                <div class="input-group">
                                    <input asp-for="TauxTVA" class="form-control" type="number" step="0.1" min="0" max="100" />
                                    <span class="input-group-text">%</span>
                                </div>
                            </div>
                        </div>
                    </div>

                    @if (Model.Statut != "Livré")
                    {
                        <div class="alert alert-warning">
                            <i class="bi bi-info-circle me-2"></i>
                            Passer le statut à <strong>Livré</strong> mettra automatiquement à jour les stocks des produits.
                        </div>
                    }

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-save me-1"></i> Enregistrer
                        </button>
                        <a asp-action="AddProduct" asp-route-id="@Model.Id" class="btn btn-outline-info">
                            <i class="bi bi-cart-plus me-1"></i> Gérer les produits
                        </a>
                        <a asp-action="Index" class="btn btn-outline-secondary">Annuler</a>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <!-- Résumé -->
    <div class="col-lg-5">
        <div class="card">
            <div class="card-header" style="background:#f0fdf4;">
                <span style="font-weight:700;color:#166534;"><i class="bi bi-receipt me-2"></i>Résumé actuel</span>
            </div>
            <div class="card-body">
                <div class="d-flex justify-content-between mb-2">
                    <span class="text-muted">Sous-total</span>
                    <strong>@Model.SousTotal.ToString("N2") DT</strong>
                </div>
                <div class="d-flex justify-content-between mb-2">
                    <span class="text-muted">Frais livraison</span>
                    <strong>@Model.FraisLivraison.ToString("N2") DT</strong>
                </div>
                <hr />
                <div class="d-flex justify-content-between">
                    <span style="font-weight:700;">Total</span>
                    <span style="font-size:1.2rem;font-weight:800;color:#2563eb;">@Model.TotalFacture.ToString("N2") DT</span>
                </div>
                <div class="mt-3">
                    <div style="font-size:.8rem;color:#64748b;">@Model.LignesCommande.Count ligne(s) de produit</div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
