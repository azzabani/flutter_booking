@model Gestion_Stock.Models.CommandeAchat
@{
    ViewData["Title"] = "Supprimer commande";
}

<div class="page-header">
    <h1 class="text-danger"><i class="bi bi-trash"></i> Supprimer commande</h1>
    <a asp-action="Index" class="btn btn-outline-secondary">
        <i class="bi bi-arrow-left me-1"></i> Retour
    </a>
</div>

<div class="row justify-content-center">
    <div class="col-lg-6">
        <div class="alert alert-danger">
            <i class="bi bi-exclamation-triangle-fill me-2"></i>
            <strong>Attention !</strong> Cette action supprimera la commande et toutes ses lignes.
        </div>
        <div class="card">
            <div class="card-header" style="background:#fef2f2;">
                <span style="font-weight:700;color:#991b1b;">Commande à supprimer</span>
            </div>
            <div class="card-body">
                <div class="info-grid">
                    <div class="info-item">
                        <div class="info-label">N° Commande</div>
                        <div class="info-value">#@Model.Id</div>
                    </div>
                    <div class="info-item">
                        <div class="info-label">Date</div>
                        <div class="info-value">@Model.DateCommande.ToString("dd/MM/yyyy")</div>
                    </div>
                    <div class="info-item">
                        <div class="info-label">Statut</div>
                        <div class="info-value">@Model.Statut</div>
                    </div>
                    <div class="info-item">
                        <div class="info-label">Total</div>
                        <div class="info-value text-primary">@Model.TotalFacture.ToString("N2") DT</div>
                    </div>
                </div>
                <form asp-action="Delete" method="post" class="mt-4 d-flex gap-2">
                    <button type="submit" class="btn btn-danger">
                        <i class="bi bi-trash me-1"></i> Confirmer la suppression
                    </button>
                    <a asp-action="Index" class="btn btn-outline-secondary">Annuler</a>
                </form>
            </div>
        </div>
    </div>
</div>
