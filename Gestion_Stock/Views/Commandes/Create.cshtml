@model Gestion_Stock.Models.CommandeAchat
@{
    ViewData["Title"] = "Nouvelle commande";
}

<div class="page-header">
    <h1><i class="bi bi-cart-plus"></i> Nouvelle commande d'achat</h1>
    <a asp-action="Index" class="btn btn-outline-secondary">
        <i class="bi bi-arrow-left me-1"></i> Retour
    </a>
</div>

<div class="row">
    <div class="col-lg-7">
        <div class="card">
            <div class="card-body">
                <form asp-action="Create" method="post">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                    <div class="form-section">
                        <div class="form-section-title"><i class="bi bi-calendar3"></i> Informations de la commande</div>
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label asp-for="DateCommande" class="form-label"></label>
                                <input asp-for="DateCommande" class="form-control" type="date" />
                                <span asp-validation-for="DateCommande" class="text-danger small"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="Statut" class="form-label"></label>
                                <select asp-for="Statut" class="form-select">
                                    <option value="En attente">En attente</option>
                                    <option value="Confirmée">Confirmée</option>
                                    <option value="Partielle">Partielle</option>
                                    <option value="Livrée">Livrée</option>
                                    <option value="Retour">Retour</option>
                                    <option value="Annulée">Annulée</option>
                                </select>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="EmployeId" class="form-label">Employé responsable</label>
                                <select asp-for="EmployeId" class="form-select" asp-items="ViewBag.EmployeId">
                                    <option value="">-- Sélectionner --</option>
                                </select>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="FournisseurId" class="form-label">Fournisseur</label>
                                <select asp-for="FournisseurId" class="form-select" asp-items="ViewBag.FournisseurId">
                                    <option value="">-- Sélectionner --</option>
                                </select>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="LivraisonId" class="form-label">Mode de livraison</label>
                                <select asp-for="LivraisonId" class="form-select" asp-items="ViewBag.LivraisonId">
                                    <option value="">-- Sélectionner --</option>
                                </select>
                            </div>
                        </div>
                    </div>

                    <div class="form-section">
                        <div class="form-section-title"><i class="bi bi-calculator"></i> Frais & TVA</div>
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label asp-for="FraisLivraison" class="form-label"></label>
                                <div class="input-group">
                                    <input asp-for="FraisLivraison" class="form-control" type="number" step="0.01" min="0" value="0" />
                                    <span class="input-group-text">DT</span>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="TauxTVA" class="form-label"></label>
                                <div class="input-group">
                                    <input asp-for="TauxTVA" class="form-control" type="number" step="0.1" min="0" max="100" value="19" />
                                    <span class="input-group-text">%</span>
                                </div>
                                <div class="form-text">TVA Tunisie standard : 19%</div>
                            </div>
                        </div>
                    </div>

                    <div class="alert alert-info">
                        <i class="bi bi-info-circle-fill me-2"></i>
                        Après création, vous pourrez ajouter les produits à la commande.
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-arrow-right-circle me-1"></i> Créer et ajouter des produits
                        </button>
                        <a asp-action="Index" class="btn btn-outline-secondary">Annuler</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
