<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Café-Restaurant Stock</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>

<nav class="navbar navbar-expand-lg">
    <div class="container-fluid" style="max-width:1400px; margin:0 auto;">
        <a class="navbar-brand" asp-controller="Home" asp-action="Index">
            <i class="bi bi-cup-hot-fill"></i> CaféStock Pro
        </a>
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navMain">
            <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="navMain">
            <ul class="navbar-nav me-auto ms-3">
                <li class="nav-item">
                    <a class="nav-link" asp-controller="Home" asp-action="Index">
                        <i class="bi bi-speedometer2"></i> Tableau de bord
                    </a>
                </li>
                <li class="nav-item dropdown">
                    <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown">
                        <i class="bi bi-box-seam"></i> Produits
                    </a>
                    <ul class="dropdown-menu">
                        <li>
                            <a class="dropdown-item" asp-controller="Produits" asp-action="Index">
                                <i class="bi bi-list-ul me-2 text-primary"></i>Liste des produits
                            </a>
                        </li>
                        <li>
                            <a class="dropdown-item" asp-controller="Produits" asp-action="Create">
                                <i class="bi bi-plus-circle me-2 text-success"></i>Nouveau produit
                            </a>
                        </li>
                        <li><hr class="dropdown-divider"></li>
                        <li>
                            <a class="dropdown-item" asp-controller="Categories" asp-action="Index">
                                <i class="bi bi-tags me-2 text-info"></i>Catégories
                            </a>
                        </li>
                    </ul>
                </li>
                <li class="nav-item dropdown">
                    <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown">
                        <i class="bi bi-cart3"></i> Commandes
                    </a>
                    <ul class="dropdown-menu">
                        <li>
                            <a class="dropdown-item" asp-controller="Commandes" asp-action="Index">
                                <i class="bi bi-list-ul me-2 text-primary"></i>Liste des commandes
                            </a>
                        </li>
                        <li>
                            <a class="dropdown-item" asp-controller="Commandes" asp-action="Create">
                                <i class="bi bi-plus-circle me-2 text-success"></i>Nouvelle commande
                            </a>
                        </li>
                    </ul>
                </li>
                <li class="nav-item">
                    <a class="nav-link" asp-controller="Fournisseurs" asp-action="Index">
                        <i class="bi bi-building"></i> Fournisseurs
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" asp-controller="Livraisons" asp-action="Index">
                        <i class="bi bi-truck"></i> Livraisons
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" asp-controller="Mouvements" asp-action="Index">
                        <i class="bi bi-arrow-left-right"></i> Mouvements
                    </a>
                </li>
                <li class="nav-item dropdown">
                    <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown">
                        <i class="bi bi-people"></i> Personnel
                    </a>
                    <ul class="dropdown-menu">
                        <li>
                            <a class="dropdown-item" asp-controller="Employes" asp-action="Index">
                                <i class="bi bi-person-badge me-2 text-primary"></i>Employés
                            </a>
                        </li>
                        <li>
                            <a class="dropdown-item" asp-controller="Commerciaux" asp-action="Index">
                                <i class="bi bi-person-check me-2 text-success"></i>Commerciaux
                            </a>
                        </li>
                    </ul>
                </li>
                @if (User.IsInRole("Admin"))
                {
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Logs" asp-action="Index">
                            <i class="bi bi-journal-text"></i> Logs
                        </a>
                    </li>
                }
            </ul>
            <!-- Utilisateur connecté + déconnexion -->
            <div class="d-flex align-items-center gap-2 ms-3">
                @if (User.Identity?.IsAuthenticated == true)
                {
                    <span class="text-white-50 small d-none d-lg-inline">
                        <i class="bi bi-person-circle me-1"></i>@User.Identity.Name
                    </span>
                    <form asp-controller="Account" asp-action="Logout" method="post" class="d-inline">
                        <button type="submit" class="btn btn-sm btn-outline-light">
                            <i class="bi bi-box-arrow-right"></i>
                        </button>
                    </form>
                }
            </div>
        </div>
    </div>
</nav>

<div class="container-fluid mt-3">
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i>@TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="bi bi-exclamation-triangle-fill me-2"></i>@TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <main role="main">
        @RenderBody()
    </main>
</div>

<footer class="mt-5">
    <div class="container text-center">
        <span><i class="bi bi-cup-hot me-1"></i> CaféStock Pro &copy; 2026 — Gestion des Matières Premières · Café-Restaurant</span>
    </div>
</footer>

<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
<script src="~/js/site.js" asp-append-version="true"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
