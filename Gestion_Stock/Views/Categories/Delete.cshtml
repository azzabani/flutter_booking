@model Gestion_Stock.Models.Categorie

@{
    ViewData["Title"] = "Supprimer la catégorie";
}

<div class="container">
    <div class="d-flex align-items-center mb-4">
        <a asp-action="Index" class="btn btn-outline-secondary me-3">
            <i class="bi bi-arrow-left"></i>
        </a>
        <h1 class="mb-0 text-danger"><i class="bi bi-trash"></i> Supprimer la catégorie</h1>
    </div>

    <div class="row">
        <div class="col-md-6">
            <div class="alert alert-danger d-flex align-items-center mb-4" role="alert">
                <i class="bi bi-exclamation-triangle-fill me-2 fs-5"></i>
                <div>Êtes-vous sûr de vouloir supprimer cette catégorie ? Cette action est irréversible.</div>
            </div>

            <div class="card border-danger">
                <div class="card-header bg-danger text-white">
                    <h5 class="card-title mb-0"><i class="bi bi-tag"></i> Résumé</h5>
                </div>
                <div class="card-body">
                    <dl class="row mb-0">
                        <dt class="col-sm-4">Nom</dt>
                        <dd class="col-sm-8"><strong>@Model.Nom</strong></dd>

                        <dt class="col-sm-4">Description</dt>
                        <dd class="col-sm-8">@(Model.Description ?? "—")</dd>

                        <dt class="col-sm-4">Produits liés</dt>
                        <dd class="col-sm-8">
                            <span class="badge bg-info">@Model.Produits.Count produit(s)</span>
                        </dd>
                    </dl>
                </div>
            </div>

            @if (Model.Produits.Count > 0)
            {
                <div class="alert alert-warning mt-3">
                    <i class="bi bi-exclamation-circle"></i>
                    Cette catégorie contient <strong>@Model.Produits.Count produit(s)</strong>. La suppression pourrait affecter ces produits.
                </div>
            }

            <form asp-action="Delete" method="post" class="mt-3">
                <input type="hidden" asp-for="Id" />
                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-danger">
                        <i class="bi bi-trash"></i> Confirmer la suppression
                    </button>
                    <a asp-action="Index" class="btn btn-outline-secondary">
                        <i class="bi bi-x-circle"></i> Annuler
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>
