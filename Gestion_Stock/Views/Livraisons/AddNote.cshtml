@model Gestion_Stock.Models.Livraison
@{
    ViewData["Title"] = "Ajouter note/avis";
}

<div class="page-header">
    <h1><i class="bi bi-star"></i> Évaluation — Livraison #@Model.Id</h1>
    <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-outline-secondary">
        <i class="bi bi-arrow-left me-1"></i> Retour
    </a>
</div>

<div class="row justify-content-center">
    <div class="col-lg-6">
        <div class="card">
            <div class="card-body">
                <form asp-action="AddNote" asp-route-id="@Model.Id" method="post">
                    <div class="mb-4">
                        <label class="form-label fw-semibold">Note (1-5 étoiles)</label>
                        <div class="d-flex gap-2">
                            @for (int i = 1; i <= 5; i++)
                            {
                                <div class="form-check form-check-inline">
                                    <input class="form-check-input" type="radio" name="noteChiffre" id="note@i" value="@i"
                                           @(Model.NoteChiffre == i ? "checked" : "") />
                                    <label class="form-check-label" for="note@i">
                                        @string.Concat(Enumerable.Repeat("⭐", i)) @i
                                    </label>
                                </div>
                            }
                        </div>
                    </div>

                    <div class="mb-4">
                        <label class="form-label fw-semibold">Avis / Commentaire</label>
                        <textarea name="noteAvis" class="form-control" rows="4"
                                  placeholder="Qualité des produits, respect des délais, état des emballages...">@Model.NoteAvis</textarea>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-save me-1"></i> Enregistrer l'évaluation
                        </button>
                        <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-outline-secondary">Annuler</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
