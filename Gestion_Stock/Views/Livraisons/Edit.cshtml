@model Gestion_Stock.Models.Livraison

@{
    ViewData["Title"] = "Modifier la livraison";
}

<div class="container">
    <div class="d-flex align-items-center mb-4">
        <a asp-action="Index" class="btn btn-outline-secondary me-3">
            <i class="bi bi-arrow-left"></i>
        </a>
        <h1 class="mb-0"><i class="bi bi-pencil-square"></i> Modifier la livraison <span class="text-muted fs-4">#@Model.Id</span></h1>
    </div>

    <div class="row">
        <div class="col-md-7">
            <div class="card">
                <div class="card-header">
                    <h5 class="card-title mb-0"><i class="bi bi-info-circle"></i> Informations</h5>
                </div>
                <div class="card-body">
                    <form asp-action="Edit" method="post">
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>
                        <input type="hidden" asp-for="Id" />

                        <div class="mb-3">
                            <label asp-for="DateLivraison" class="form-label fw-semibold"></label>
                            <input asp-for="DateLivraison" class="form-control" type="date" />
                            <span asp-validation-for="DateLivraison" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Statut" class="form-label fw-semibold"></label>
                            <select asp-for="Statut" class="form-select">
                                <option value="En attente">En attente</option>
                                <option value="En cours">En cours</option>
                                <option value="Livré">Livré</option>
                                <option value="Retour">Retour</option>
                            </select>
                            <span asp-validation-for="Statut" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="CommercialId" class="form-label fw-semibold"></label>
                            <select asp-for="CommercialId" class="form-select" asp-items="ViewBag.CommercialId">
                                <option value="">-- Sélectionner un commercial --</option>
                            </select>
                            <span asp-validation-for="CommercialId" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="NoteAvis" class="form-label fw-semibold"></label>
                            <textarea asp-for="NoteAvis" class="form-control" rows="3"></textarea>
                            <span asp-validation-for="NoteAvis" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Note" class="form-label fw-semibold"></label>
                            <textarea asp-for="Note" class="form-control" rows="2"></textarea>
                            <span asp-validation-for="Note" class="text-danger small"></span>
                        </div>

                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-warning">
                                <i class="bi bi-save"></i> Enregistrer
                            </button>
                            <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-outline-info">
                                <i class="bi bi-eye"></i> Détails
                            </a>
                            <a asp-action="Index" class="btn btn-outline-secondary">
                                <i class="bi bi-x-circle"></i> Annuler
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
