@model Gestion_Stock.Models.Livraison

@{
    ViewData["Title"] = "Supprimer la livraison";
}

<div class="container">
    <div class="d-flex align-items-center mb-4">
        <a asp-action="Index" class="btn btn-outline-secondary me-3">
            <i class="bi bi-arrow-left"></i>
        </a>
        <h1 class="mb-0 text-danger"><i class="bi bi-trash"></i> Supprimer la livraison</h1>
    </div>

    <div class="row">
        <div class="col-md-6">
            <div class="alert alert-danger d-flex align-items-center mb-4" role="alert">
                <i class="bi bi-exclamation-triangle-fill me-2 fs-5"></i>
                <div>Êtes-vous sûr de vouloir supprimer cette livraison ? Cette action est irréversible.</div>
            </div>

            <div class="card border-danger">
                <div class="card-header bg-danger text-white">
                    <h5 class="card-title mb-0"><i class="bi bi-truck"></i> Résumé — Livraison #@Model.Id</h5>
                </div>
                <div class="card-body">
                    <dl class="row mb-0">
                        <dt class="col-sm-5">Date</dt>
                        <dd class="col-sm-7">@Model.DateLivraison.ToString("dd/MM/yyyy")</dd>

                        <dt class="col-sm-5">Statut</dt>
                        <dd class="col-sm-7">
                            @{
                                var badgeClass = Model.Statut switch {
                                    "Livré" => "bg-success",
                                    "En attente" => "bg-warning text-dark",
                                    "En cours" => "bg-info",
                                    "Retour" => "bg-danger",
                                    _ => "bg-secondary"
                                };
                            }
                            <span class="badge @badgeClass">@Model.Statut</span>
                        </dd>

                        <dt class="col-sm-5">Commercial</dt>
                        <dd class="col-sm-7">@(Model.Commercial?.Nom ?? "—")</dd>

                        <dt class="col-sm-5">Notes/Avis</dt>
                        <dd class="col-sm-7">@(Model.NoteAvis ?? "—")</dd>

                        <dt class="col-sm-5">Commandes</dt>
                        <dd class="col-sm-7">
                            <span class="badge bg-info">@Model.Commandes.Count commande(s)</span>
                        </dd>
                    </dl>
                </div>
            </div>

            @if (Model.Commandes.Count > 0)
            {
                <div class="alert alert-warning mt-3">
                    <i class="bi bi-exclamation-circle"></i>
                    Cette livraison contient <strong>@Model.Commandes.Count commande(s)</strong>. La suppression pourrait affecter ces commandes.
                </div>
            }

            <form asp-action="Delete" method="post" class="mt-3">
                <input type="hidden" asp-for="Id" />
                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-danger">
                        <i class="bi bi-trash"></i> Confirmer la suppression
                    </button>
                    <a asp-action="Index" class="btn btn-outline-secondary">
                        <i class="bi bi-x-circle"></i> Annuler
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>
