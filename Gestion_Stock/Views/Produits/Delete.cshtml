@model Gestion_Stock.Models.Produit
@{
    ViewData["Title"] = "Supprimer produit";
}

<div class="page-header">
    <h1 class="text-danger"><i class="bi bi-trash"></i> Supprimer produit</h1>
    <a asp-action="Index" class="btn btn-outline-secondary">
        <i class="bi bi-arrow-left me-1"></i> Retour
    </a>
</div>

<div class="row justify-content-center">
    <div class="col-lg-6">
        <div class="alert alert-danger">
            <i class="bi bi-exclamation-triangle-fill me-2"></i>
            <strong>Attention !</strong> Cette action est irréversible. Toutes les données associées seront supprimées.
        </div>

        <div class="card">
            <div class="card-header" style="background:#fef2f2;">
                <span style="font-weight:700;color:#991b1b;">Produit à supprimer</span>
            </div>
            <div class="card-body">
                <div class="info-grid">
                    <div class="info-item">
                        <div class="info-label">Nom</div>
                        <div class="info-value">@Model.Nom</div>
                    </div>
                    <div class="info-item">
                        <div class="info-label">Référence</div>
                        <div class="info-value">@(Model.Reference ?? "—")</div>
                    </div>
                    <div class="info-item">
                        <div class="info-label">Catégorie</div>
                        <div class="info-value">@Model.Categorie?.Nom</div>
                    </div>
                    <div class="info-item">
                        <div class="info-label">Stock actuel</div>
                        <div class="info-value">@Model.StockActuel unités</div>
                    </div>
                </div>

                <form asp-action="Delete" method="post" class="mt-4 d-flex gap-2">
                    <button type="submit" class="btn btn-danger">
                        <i class="bi bi-trash me-1"></i> Confirmer la suppression
                    </button>
                    <a asp-action="Index" class="btn btn-outline-secondary">Annuler</a>
                </form>
            </div>
        </div>
    </div>
</div>
