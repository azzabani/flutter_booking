@model Gestion_Stock.Models.Produit
@{
    ViewData["Title"] = "Détails produit";
    int pct = Model.SeuilMax > 0 ? (int)Math.Min(100, (double)Model.StockActuel / Model.SeuilMax * 100) : 0;
    string barColor = Model.StockActuel <= Model.SeuilMin ? "#ef4444" : Model.StockActuel >= Model.SeuilMax ? "#f59e0b" : "#22c55e";
}

<div class="page-header">
    <h1><i class="bi bi-box-seam"></i> @Model.Nom</h1>
    <div class="d-flex gap-2">
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">
            <i class="bi bi-pencil me-1"></i> Modifier
        </a>
        <a asp-action="Index" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left me-1"></i> Retour
        </a>
    </div>
</div>

<div class="row g-3">
    <!-- Infos principales -->
    <div class="col-lg-4">
        <div class="card">
            <div class="card-header" style="background:#fff;">
                <span style="font-weight:700;"><i class="bi bi-info-circle text-primary me-2"></i>Informations</span>
            </div>
            <div class="card-body">
                <div class="info-grid" style="grid-template-columns:1fr;">
                    <div class="info-item">
                        <div class="info-label">Référence</div>
                        <div class="info-value"><code>@(Model.Reference ?? "—")</code></div>
                    </div>
                    <div class="info-item">
                        <div class="info-label">Catégorie</div>
                        <div class="info-value">@Model.Categorie?.Nom</div>
                    </div>
                    <div class="info-item">
                        <div class="info-label">Prix unitaire</div>
                        <div class="info-value text-primary">@Model.PrixUnitaire.ToString("N2") DT</div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Stock -->
        <div class="card mt-3">
            <div class="card-header" style="background:#fff;">
                <span style="font-weight:700;"><i class="bi bi-bar-chart text-success me-2"></i>Niveau de stock</span>
            </div>
            <div class="card-body">
                <div class="text-center mb-3">
                    <div style="font-size:2.5rem;font-weight:800;color:@barColor;">@Model.StockActuel</div>
                    <div style="font-size:.8rem;color:#64748b;">unités en stock</div>
                </div>
                <div class="stock-bar" style="height:10px;">
                    <div class="stock-bar-fill" style="width:@pct%;background:@barColor;"></div>
                </div>
                <div class="d-flex justify-content-between mt-1" style="font-size:.75rem;color:#94a3b8;">
                    <span>Min: @Model.SeuilMin</span>
                    <span>Max: @Model.SeuilMax</span>
                </div>
                <div class="text-center mt-3">
                    @if (Model.StockActuel <= Model.SeuilMin)
                    {
                        <span class="badge bg-danger fs-6"><i class="bi bi-exclamation-triangle me-1"></i>Besoin d'approvisionnement</span>
                    }
                    else if (Model.StockActuel >= Model.SeuilMax)
                    {
                        <span class="badge bg-warning fs-6"><i class="bi bi-arrow-up me-1"></i>Ne plus approvisionner</span>
                    }
                    else
                    {
                        <span class="badge bg-success fs-6"><i class="bi bi-check me-1"></i>Stock normal</span>
                    }
                </div>
            </div>
        </div>
    </div>

    <!-- Fournisseurs + Mouvements -->
    <div class="col-lg-8">
        <!-- Fournisseurs -->
        <div class="card mb-3">
            <div class="card-header" style="background:#fff;">
                <span style="font-weight:700;"><i class="bi bi-building text-info me-2"></i>Fournisseurs (@Model.FournisseurProduits.Count)</span>
            </div>
            <div class="card-body p-0">
                @if (Model.FournisseurProduits.Any())
                {
                    <table class="table mb-0">
                        <thead>
                            <tr>
                                <th>Fournisseur</th>
                                <th class="text-end">Prix d'achat</th>
                                <th class="text-end">Délai (jours)</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var fp in Model.FournisseurProduits.OrderBy(f => f.PrixAchat))
                            {
                                <tr>
                                    <td><i class="bi bi-building me-1 text-muted"></i>@fp.Fournisseur?.Nom</td>
                                    <td class="text-end"><span class="badge bg-success">@fp.PrixAchat.ToString("N2") DT</span></td>
                                    <td class="text-end">@fp.DelaiLivraisonJours j</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
                else
                {
                    <div class="empty-state" style="padding:1.5rem;">
                        <p>Aucun fournisseur associé</p>
                    </div>
                }
            </div>
        </div>

        <!-- Mouvements de stock -->
        <div class="card">
            <div class="card-header" style="background:#fff;">
                <span style="font-weight:700;"><i class="bi bi-arrow-left-right text-warning me-2"></i>Derniers mouvements de stock</span>
            </div>
            <div class="card-body p-0">
                @if (Model.MouvementsStock.Any())
                {
                    <table class="table mb-0">
                        <thead>
                            <tr>
                                <th>Date</th>
                                <th>Type</th>
                                <th class="text-end">Quantité</th>
                                <th>Raison</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var m in Model.MouvementsStock.OrderByDescending(m => m.DateMouvement).Take(10))
                            {
                                <tr>
                                    <td style="font-size:.8rem;">@m.DateMouvement.ToString("dd/MM/yyyy HH:mm")</td>
                                    <td>
                                        @if (m.TypeMouvement == "Entrée")
                                        {
                                            <span class="badge bg-success"><i class="bi bi-arrow-down me-1"></i>@m.TypeMouvement</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-danger"><i class="bi bi-arrow-up me-1"></i>@m.TypeMouvement</span>
                                        }
                                    </td>
                                    <td class="text-end fw-bold">@m.Quantite</td>
                                    <td style="font-size:.82rem;color:#64748b;">@(m.Raison ?? "—")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
                else
                {
                    <div class="empty-state" style="padding:1.5rem;">
                        <p>Aucun mouvement de stock</p>
                    </div>
                }
            </div>
        </div>
    </div>
</div>
