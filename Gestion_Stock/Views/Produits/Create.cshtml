@model Gestion_Stock.Models.Produit
@{
    ViewData["Title"] = "Nouveau produit";
}

<div class="page-header">
    <h1><i class="bi bi-plus-circle"></i> Nouveau produit</h1>
    <a asp-action="Index" class="btn btn-outline-secondary">
        <i class="bi bi-arrow-left me-1"></i> Retour
    </a>
</div>

<div class="row">
    <div class="col-lg-7">
        <div class="card">
            <div class="card-body">
                <form asp-action="Create" method="post">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                    <div class="form-section">
                        <div class="form-section-title"><i class="bi bi-info-circle"></i> Informations générales</div>
                        <div class="row g-3">
                            <div class="col-md-8">
                                <label asp-for="Nom" class="form-label"></label>
                                <input asp-for="Nom" class="form-control" placeholder="Nom du produit" />
                                <span asp-validation-for="Nom" class="text-danger small"></span>
                            </div>
                            <div class="col-md-4">
                                <label asp-for="Reference" class="form-label"></label>
                                <input asp-for="Reference" class="form-control" placeholder="REF-001" />
                                <span asp-validation-for="Reference" class="text-danger small"></span>
                            </div>
                            <div class="col-12">
                                <label asp-for="CategorieId" class="form-label"></label>
                                <select asp-for="CategorieId" class="form-select" asp-items="ViewBag.CategorieId">
                                    <option value="">-- Sélectionner une catégorie --</option>
                                </select>
                                <span asp-validation-for="CategorieId" class="text-danger small"></span>
                            </div>
                        </div>
                    </div>

                    <div class="form-section">
                        <div class="form-section-title"><i class="bi bi-currency-dollar"></i> Prix & Stock</div>
                        <div class="row g-3">
                            <div class="col-md-4">
                                <label asp-for="PrixUnitaire" class="form-label"></label>
                                <div class="input-group">
                                    <input asp-for="PrixUnitaire" class="form-control" type="number" step="0.01" min="0" />
                                    <span class="input-group-text">DT</span>
                                </div>
                                <span asp-validation-for="PrixUnitaire" class="text-danger small"></span>
                            </div>
                            <div class="col-md-4">
                                <label asp-for="StockActuel" class="form-label"></label>
                                <input asp-for="StockActuel" class="form-control" type="number" min="0" />
                                <span asp-validation-for="StockActuel" class="text-danger small"></span>
                            </div>
                            <div class="col-md-4">
                                <label asp-for="Unite" class="form-label"></label>
                                <select asp-for="Unite" class="form-select">
                                    <option value="kg">kg (kilogramme)</option>
                                    <option value="g">g (gramme)</option>
                                    <option value="L">L (litre)</option>
                                    <option value="cl">cl (centilitre)</option>
                                    <option value="unité">unité</option>
                                    <option value="sachet">sachet</option>
                                    <option value="boîte">boîte</option>
                                    <option value="bouteille">bouteille</option>
                                    <option value="carton">carton</option>
                                    <option value="barquette">barquette</option>
                                </select>
                            </div>
                        </div>
                    </div>

                    <div class="form-section">
                        <div class="form-section-title"><i class="bi bi-sliders"></i> Seuils d'alerte</div>
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label asp-for="SeuilMin" class="form-label"></label>
                                <div class="input-group">
                                    <span class="input-group-text text-danger"><i class="bi bi-arrow-down"></i></span>
                                    <input asp-for="SeuilMin" class="form-control" type="number" min="0" />
                                </div>
                                <div class="form-text">Alerte approvisionnement si stock ≤ cette valeur</div>
                                <span asp-validation-for="SeuilMin" class="text-danger small"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="SeuilMax" class="form-label"></label>
                                <div class="input-group">
                                    <span class="input-group-text text-warning"><i class="bi bi-arrow-up"></i></span>
                                    <input asp-for="SeuilMax" class="form-control" type="number" min="0" />
                                </div>
                                <div class="form-text">Alerte surstock si stock ≥ cette valeur</div>
                                <span asp-validation-for="SeuilMax" class="text-danger small"></span>
                            </div>
                        </div>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-save me-1"></i> Enregistrer
                        </button>
                        <a asp-action="Index" class="btn btn-outline-secondary">Annuler</a>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <div class="col-lg-5">
        <div class="card">
            <div class="card-header" style="background:#fffbeb;">
                <span style="font-weight:700;color:#92400e;"><i class="bi bi-lightbulb me-2"></i>Conseils</span>
            </div>
            <div class="card-body">
                <ul class="list-unstyled" style="font-size:.85rem;color:#64748b;">
                    <li class="mb-2"><i class="bi bi-check-circle text-success me-2"></i>La référence doit être unique</li>
                    <li class="mb-2"><i class="bi bi-check-circle text-success me-2"></i>Le seuil min déclenche une alerte d'approvisionnement</li>
                    <li class="mb-2"><i class="bi bi-check-circle text-success me-2"></i>Le seuil max déclenche une alerte de surstock</li>
                    <li class="mb-2"><i class="bi bi-check-circle text-success me-2"></i>Seuil min doit être inférieur au seuil max</li>
                </ul>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
